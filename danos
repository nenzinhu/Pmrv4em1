
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Danos Parentes</title>

  <style>
    :root{
      --bg:#071028;
      --card:#0b1220;
      --accent:#4f46e5;
      --accent2:#06b6d4;
      --muted:#94a3b8;
      --radius:14px;
    }
    *{box-sizing:border-box}

    body{
      margin:0;
      min-height:100vh;
      background:linear-gradient(180deg,#071028,#071a2a);
      color:#e6eef8;
      font-family:system-ui, Arial, sans-serif;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:16px;
    }

    .box{
      width:100%;
      max-width:360px;
      background:var(--card);
      border-radius:var(--radius);
      padding:22px;
      box-shadow:0 20px 60px rgba(2,6,23,.7);
      text-align:center;
    }

    h1{
      margin:0 0 6px 0;
      font-size:18px;
    }

    p{
      margin:0 0 18px 0;
      font-size:12px;
      color:var(--muted);
    }

    .options{
      display:flex;
      flex-direction:column;
      gap:12px;
    }

    .option{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:14px;
      border-radius:12px;
      background:rgba(255,255,255,0.03);
      border:1px solid rgba(255,255,255,0.04);
      text-decoration:none;
      color:inherit;
      cursor:pointer;
      transition:transform .12s ease, box-shadow .12s ease;
    }

    .option:hover{
      transform:translateY(-3px);
      box-shadow:0 10px 30px rgba(2,6,23,.6);
    }

    .left{
      display:flex;
      align-items:center;
      gap:12px;
      text-align:left;
    }

    .icon{
      width:42px;
      height:42px;
      border-radius:10px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:22px;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
    }

    .title{
      font-weight:700;
      font-size:14px;
    }

    .desc{
      font-size:11px;
      color:var(--muted);
      margin-top:2px;
    }

    .arrow{
      font-size:18px;
      color:var(--muted);
    }

    footer{
      margin-top:16px;
      font-size:11px;
      color:var(--muted);
    }
  </style>
</head>

<body>
  <div class="box">
    <h1>Danos Parentes</h1>
    <p>Selecione o tipo de vistoria</p>

    <div class="options">
      <!-- CARRO -->
      <a class="option" href="./carro/index.html">
        <div class="left">
          <div class="icon">🚗</div>
          <div>
            <div class="title">Carro</div>
            <div class="desc">Vistoria de automóvel</div>
          </div>
        </div>
        <div class="arrow">›</div>
      </a>

      <!-- MOTOCICLETA -->
      <a class="option" href="./motocicleta/index.html">
        <div class="left">
          <div class="icon">🏍️</div>
          <div>
            <div class="title">Motocicleta</div>
            <div class="desc">Vistoria de moto</div>
          </div>
        </div>
        <div class="arrow">›</div>
      </a>
    </div>

    <footer>
      Sistema de registro de danos aparentes
    </footer>
  </div>
</body>
</html>
